# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql+asyncpg://truematch:password@localhost:5432/truematch

# ============================================================================
# REDIS / CELERY
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# ANTHROPIC / LLM
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
LLM_TIMEOUT_SECONDS=60
LLM_FORCE_MOCK=false

# ============================================================================
# EMAIL / SMTP CONFIGURATION
# ============================================================================
# Choose ONE email provider:
# Option 1: Standard SMTP (Gmail, SendGrid SMTP, custom SMTP servers)
# Option 2: SendGrid API (requires API key)
# Option 3: AWS SES (requires AWS credentials)

# --- OPTION 1: STANDARD SMTP (recommended for most cases) ---
# Gmail: Use App Passwords (https://support.google.com/accounts/answer/185833)
# Other providers: Check their SMTP documentation
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@truematch.ai
SMTP_FROM_NAME=TrueMatch
SMTP_USE_TLS=true

# --- OPTION 2: SENDGRID (alternative - requires library: pip install sendgrid) ---
# SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# --- OPTION 3: AWS SES (alternative - requires library: pip install boto3) ---
# AWS_SES_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# ============================================================================
# AUTHENTICATION
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRY_MINUTES=30
REFRESH_TOKEN_EXPIRY_DAYS=7

# Singpass OIDC (Singapore national ID authentication)
SINGPASS_ISSUER=https://stg-id.singpass.gov.sg
SINGPASS_CLIENT_ID=your-singpass-client-id
SINGPASS_CLIENT_SECRET=your-singpass-client-secret
SINGPASS_SIG_JWK_PATH=./config/singpass_sig.json
SINGPASS_ENC_JWK_PATH=./config/singpass_enc.json

# ============================================================================
# SEMANTIC MATCHING
# ============================================================================
SEMANTIC_USE_EMBEDDINGS=true
SEMANTIC_EMBEDDING_MODEL=minishlab/potion-base-8M
SEMANTIC_EMBEDDING_THRESHOLD=0.40
SEMANTIC_CONFIRM_THRESHOLD=60

# ============================================================================
# INTAKE / INGESTION
# ============================================================================
INGEST_CV_FOLDER=./inbox/cv
INGEST_JD_FOLDER=./inbox/jd
INGEST_FOLDER_POLL_SECONDS=30
INGEST_MAX_RETRIES=3
INGEST_REQUIRE_APPROVAL=false

# IMAP (for email-based CV ingestion - leave empty to disable)
INGEST_IMAP_HOST=
INGEST_IMAP_PORT=993
INGEST_IMAP_USER=
INGEST_IMAP_PASSWORD=
INGEST_IMAP_FOLDER=INBOX
INGEST_EMAIL_POLL_SECONDS=60

# ============================================================================
# S3 / FILE STORAGE
# ============================================================================
S3_BUCKET=your-s3-bucket-name
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ============================================================================
# APPLICATION
# ============================================================================
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_JSON=true
LOG_LEVEL=INFO

# Monitoring
SENTRY_DSN=
METRICS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
