# ============================================================================
# TrueMatch Backend Configuration (.env.example)
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Environment-specific files:
# - .env (development, loaded by default)
# - .env.staging (staging environment)
# - .env.production (production, never committed)

# ============================================================================
# APPLICATION ENVIRONMENT
# ============================================================================
# Controls validation strictness and default values
# - development: warnings OK, flexible defaults
# - staging: all critical secrets required
# - production: strict validation, all secrets mandatory
ENVIRONMENT=development

# ============================================================================
# DATABASE (CRITICAL)
# ============================================================================
# PostgreSQL connection string for async operations
# CRITICAL: Required in all environments
#
# Format: postgresql+asyncpg://user:password@host:port/database
#
# Examples:
#   Local: postgresql+asyncpg://truematch:password@localhost:5432/truematch
#   RDS:   postgresql+asyncpg://user:pass@truematch-db.c123456.us-east-1.rds.amazonaws.com:5432/truematch
#
# Production Note: Never use localhost in production
DATABASE_URL=postgresql+asyncpg://truematch:password@localhost:5432/truematch

# ============================================================================
# REDIS (CRITICAL)
# ============================================================================
# Redis connection for rate limiting, token denylist, and caching
# CRITICAL: Required in all environments
#
# Format: redis://[user:password@]host:port[/db]
#
# Examples:
#   Local:     redis://localhost:6379/0
#   Elastica:  redis://default:password@redis.example.com:6379/0
#
# Production Note: Never use localhost in production
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# ENCRYPTION (CRITICAL FOR PRODUCTION)
# ============================================================================
# Field-level encryption for PII at rest (compliance: PDPA, GDPR, etc.)
#
# CRITICAL: Production deployments MUST set these
# If unset: data is stored unencrypted (dev only) and logs a warning
#
# MUST be BASE64 that decodes to exactly 32 bytes (AES-256). NOT hex.
# Generate with: python -c "import base64,secrets; print(base64.b64encode(secrets.token_bytes(32)).decode())"
#
# ENCRYPTION_KEY: base64-encoded 32-byte AES-256 data encryption key
ENCRYPTION_KEY=

# ENCRYPTION_INDEX_KEY: 32-byte HMAC key for searchable blind indexes
ENCRYPTION_INDEX_KEY=

# ============================================================================
# AUTHENTICATION (CRITICAL)
# ============================================================================
# JWT token signing and expiry configuration

# JWT Secret: Signing key for JWT tokens (32+ characters)
# CRITICAL: Production MUST use a strong random secret
# CRITICAL: Never use 'change-me' or weak default values
#
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me

# JWT algorithm (typically HS256 for symmetric key signing)
JWT_ALGORITHM=HS256

# Token expiry times
# - Access tokens: short-lived (30 minutes typical)
# - Refresh tokens: long-lived (7 days typical)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Singpass OIDC (Singapore national identity authentication)
# Only required if deploying to Singapore or using Singpass login
#
# Singpass Issuer: OIDC discovery URL
# - Development: https://stg-id.singpass.gov.sg (staging NDI)
# - Production: https://id.singpass.gov.sg (real NDI)
SINGPASS_ISSUER=

# Singpass Client ID: Your app's registered client ID from ACRA
SINGPASS_CLIENT_ID=

# Singpass JWK Paths: Paths to your private JSON Web Key files
# Provided by Singpass when you register your application
# Store these securely; never commit to git
SINGPASS_SIG_JWK_PATH=
SINGPASS_ENC_JWK_PATH=

# Singpass state TTL: How long login state is cached server-side (seconds)
SINGPASS_STATE_TTL_SECONDS=600

# ============================================================================
# S3 / FILE STORAGE (REQUIRED FOR FILE UPLOADS)
# ============================================================================
# AWS S3 credentials for resume/CV file uploads
#
# CRITICAL: Never use 'placeholder' values in production
# CRITICAL: Both access key and secret key required
#
# Getting AWS Credentials:
# 1. Create an AWS IAM user with S3 permissions
# 2. Generate access key / secret access key
# 3. Restrict permissions to specific S3 bucket
#
# Example IAM policy:
# {
#   "Effect": "Allow",
#   "Action": [
#     "s3:PutObject",
#     "s3:GetObject",
#     "s3:DeleteObject",
#     "s3:ListBucket"
#   ],
#   "Resource": [
#     "arn:aws:s3:::truematch-uploads/*",
#     "arn:aws:s3:::truematch-uploads"
#   ]
# }

# AWS Access Key ID: 20-character alphanumeric ID
AWS_ACCESS_KEY_ID=

# AWS Secret Access Key: 40-character secret key
AWS_SECRET_ACCESS_KEY=

# S3 Bucket Name: Your bucket for file uploads
S3_BUCKET=truematch-uploads

# AWS Region: Region where S3 bucket is located
# Examples: us-east-1, eu-west-1, ap-southeast-1
AWS_REGION=ap-southeast-1

# Optional: AWS KMS key ID for server-side encryption
# When set, objects use aws:kms; otherwise AES256 (SSE-S3)
# All uploads are encrypted either way
S3_KMS_KEY_ID=

# Max upload size in bytes (default 5 MB)
MAX_UPLOAD_BYTES=5000000

# ============================================================================
# ANTHROPIC / LANGUAGE MODEL
# ============================================================================
# Anthropic Claude API for CV/JD analysis and matching

# API Key: Your Anthropic API key (sk-ant-...)
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model: Claude model to use for LLM tasks
# Current options: claude-sonnet-4-20250514, claude-opus-4-1, etc.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Timeout: How long to wait for LLM responses (seconds)
LLM_TIMEOUT_SECONDS=60

# Force Mock: Use deterministic mocks even if API key is present (testing)
LLM_FORCE_MOCK=false

# ============================================================================
# SEMANTIC MATCHING
# ============================================================================
# Configuration for embedding-based CV/JD semantic matching

# Enable embeddings: Use semantic embeddings vs lexical matching only
SEMANTIC_USE_EMBEDDINGS=true

# Embedding model: HuggingFace model for semantic analysis. The multilingual
# model (101 languages) enables non-English and cross-lingual matching; the
# English-only potion-base-8M is the lighter alternative for English-only deploys.
SEMANTIC_EMBEDDING_MODEL=minishlab/potion-multilingual-128M

# Embedding threshold: Minimum similarity score for matches (0.0-1.0)
SEMANTIC_EMBEDDING_THRESHOLD=0.40

# Confirmation threshold: Score at which candidate is "strong match" (0-100)
SEMANTIC_CONFIRM_THRESHOLD=60

# External enrichment: Fetch supplementary evidence links from web
# WARNING: Only enable if you have outbound network access
ENRICHMENT_ENABLED=false
ENRICHMENT_TIMEOUT_SECONDS=12.0
# Optional Lens.org patent API token. When set, filed patent numbers are
# cross-checked against the public patent record and promoted to "verified"
# once the application publishes. Blank = patents stay recorded-but-unverified
# with an honest "verifiable on publication" reason (never silently confirmed).
LENS_API_TOKEN=

# Transition Intelligence (predict adjacent/higher roles + upskilling + timeline)
TRANSITION_INTELLIGENCE_ENABLED=true
# Training recommendations (Phase 2). The curated catalog is built-in/offline-safe.
# External partners are individually gated and are no-ops until configured.
TRAINING_RECOMMENDATIONS_ENABLED=true
TRAINING_CURATED_ENABLED=true
# Example partner (NTUC LearningHub): set enabled + api base/key to switch on.
NTUC_LEARNINGHUB_ENABLED=false
NTUC_LEARNINGHUB_API_BASE=
NTUC_LEARNINGHUB_API_KEY=

# ============================================================================
# EMAIL / NOTIFICATIONS
# ============================================================================
# Email configuration for notifications and ingestion

# Choose ONE email provider:
# - SMTP (recommended): Standard SMTP server (Gmail, SendGrid, custom)
# - SendGrid API: SendGrid's HTTP API
# - AWS SES: AWS Simple Email Service

# --- OPTION 1: STANDARD SMTP ---
# SMTP Server: Mail server hostname
# Examples: smtp.gmail.com, smtp.sendgrid.net, mail.example.com
SMTP_SERVER=smtp.gmail.com

# SMTP Port: TLS port (usually 587 for TLS, 465 for SMTPS, 25 for plain)
SMTP_PORT=587

# SMTP Username: Email account for sending
# For Gmail: your@gmail.com or app-specific email
# For SendGrid: 'apikey' (username is literal)
SMTP_USERNAME=your-email@gmail.com

# SMTP Password: Email password or app-specific password
# For Gmail: Generate app-specific password (https://support.google.com/accounts/answer/185833)
SMTP_PASSWORD=your-app-specific-password

# SMTP From: Email address to use as sender
SMTP_FROM_EMAIL=noreply@truematch.ai

# SMTP From Name: Display name for sender
SMTP_FROM_NAME=TrueMatch

# SMTP Use TLS: Enable TLS encryption
SMTP_USE_TLS=true

# --- OPTION 2: SENDGRID API ---
# Uncomment and set your SendGrid API key
# SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# --- OPTION 3: AWS SES ---
# Uncomment and set your AWS region
# AWS_SES_REGION=us-east-1
# (uses AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY above)

# ============================================================================
# EMAIL INGESTION (IMAP)
# ============================================================================
# Monitor an email inbox for CV/JD documents
# Leave empty to disable email ingestion

# IMAP Server: Email provider's IMAP server
# Examples: imap.gmail.com, imap.outlook.com
IMAP_HOST=

# IMAP Port: Usually 993 (secure)
IMAP_PORT=993

# IMAP Username: Your email address
IMAP_USER=

# IMAP Password: Email password or app-specific password
IMAP_PASSWORD=

# Folder to monitor: Usually "INBOX"
IMAP_FOLDER=INBOX

# Poll interval: How often to check for emails (seconds)
IMAP_POLL_SECONDS=300

# ============================================================================
# FILE INGESTION (FILESYSTEM)
# ============================================================================
# Monitor local folders for CV and JD documents

# CV Folder: Path to monitor for resume files
INGEST_CV_FOLDER=./inbox/cv

# JD Folder: Path to monitor for job description files
INGEST_JD_FOLDER=./inbox/jd

# Poll interval: How often to check folders (seconds)
INGEST_FOLDER_POLL_SECONDS=30

# Max retries: How many times to retry a failed ingest
INGEST_MAX_RETRIES=3

# Require approval: Require human approval before processing CVs
INGEST_REQUIRE_APPROVAL=false

# Assessment inbox: Path for assessment documents
ASSESSMENT_INBOX_PATH=./inbox/assessments

# ============================================================================
# GOVERNANCE (AUTONOMY LAYER)
# ============================================================================
# Configuration for autonomous decision gates

# Config file path: External JSON file with governance rules
# See: governance/config.example.json
GOVERNANCE_CONFIG_PATH=./governance/config.example.json

# Auto-approval threshold: Score >= this auto-approves candidates
AUTO_APPROVE_THRESHOLD=0.90

# Auto-rejection threshold: Score < this auto-rejects candidates
AUTO_REJECT_THRESHOLD=0.40

# Review threshold: Score between reject/approve requires manual review
DECISION_REVIEW_THRESHOLD=0.65

# Enable specific governance gates
GOVERNANCE_ENABLE_COHERENCE_GATE=true
GOVERNANCE_ENABLE_CONSISTENCY_GATE=true
GOVERNANCE_ENABLE_FIDELITY_GATE=true
GOVERNANCE_ENABLE_BIAS_GATE=true

# ============================================================================
# OBSERVABILITY & MONITORING
# ============================================================================

# Log JSON: Output logs as JSON (set false for human-readable)
LOG_JSON=true

# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Sentry DSN: Error tracking service
# Get from: https://sentry.io/
# Leave empty to disable error tracking
SENTRY_DSN=

# Metrics: Enable Prometheus metrics at /metrics
METRICS_ENABLED=true

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120

# ============================================================================
# API / CORS
# ============================================================================

# CORS Origins: Comma-separated list of allowed frontend origins
# Examples: http://localhost:3000,http://localhost:5173,https://app.truematch.ai
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================================
# PHASE A: AUTONOMY LAYER
# ============================================================================

# Email ingestion (IMAP)
EMAIL_INGESTION_ENABLED=false
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_POLL_INTERVAL=300

# Email sending (SMTP) - see EMAIL section above for config

# Assessment processing
MAX_CONCURRENT_ASSESSMENTS=5
ASSESSMENT_TIMEOUT_SECONDS=60

# Slack notifications
SLACK_WEBHOOK_URL=
SLACK_NOTIFICATIONS_ENABLED=false

# ── Billing & payments (Stripe) ──────────────────────────────────────────────
# Empty = billing is a safe no-op (checkout 503, assessments unmetered).
# See BILLING_GOLIVE.md for the full setup. Card data never touches our servers
# (Stripe-hosted Checkout, PCI SAQ A). PayNow is enabled via Stripe for SGD.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
BILLING_CURRENCY=usd
BILLING_SUCCESS_URL=http://localhost:3000/billing/success?session_id={CHECKOUT_SESSION_ID}
BILLING_CANCEL_URL=http://localhost:3000/pricing?canceled=1
BILLING_ENFORCE=false
# Referrals (two-sided credit grant)
REFERRAL_ENABLED=true
REFERRAL_REWARD_CREDITS=1
SHARE_BASE_URL=http://localhost:3000/share

# ===== Backup LLM provider (MiniMax) — automatic failover when Anthropic fails =====
# Leave MINIMAX_API_KEY blank to disable failover (Anthropic-only). NOTE (PDPA):
# enabling this routes candidate PII to MiniMax (PRC-based) — confirm region/DPA.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.5
LLM_FALLBACK_ENABLED=true
