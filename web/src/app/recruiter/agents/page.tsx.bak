"use client";

import { useState, useEffect, useRef } from "react";
import Link from "next/link";
import {
  Inbox, FileText, Activity, CheckCircle2, XCircle,
  AlertTriangle, Clock, Zap, TrendingUp, Upload, Plus,
  RefreshCw, ChevronRight
} from "lucide-react";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import type { IngestQueueItem } from "@/lib/api";

/* ── mock event feed ──────────────────────────────────────────────────── */
const MOCK_EVENTS = [
  { time: "14:32", type: "cv",      icon: Zap,          color: "text-amber-500",   text: "Maya O. → AI Leader — matched (Sem 72%)" },
  { time: "14:31", type: "jd",      icon: FileText,     color: "text-blue-500",    text: "JD 'Ecosystem Director' analysed — quality 75/100" },
  { time: "14:28", type: "assess",  icon: CheckCircle2, color: "text-emerald-500", text: "Assessment complete — M. Reezan · δ+65" },
  { time: "14:25", type: "beat",    icon: Activity,     color: "text-slate-400",   text: "Beat: poll-cv-folder succeeded (0.3s, 0 new)" },
  { time: "14:20", type: "cv",      icon: Inbox,        color: "text-purple-500",  text: "CV ingested — Sarah Chen → Backend Eng" },
  { time: "14:15", type: "beat",    icon: Activity,     color: "text-slate-400",   text: "Beat: poll-jd-folder succeeded (0.0s, 0 new)" },
  { time: "14:10", type: "assess",  icon: TrendingUp,   color: "text-primary",     text: "Assessment queued — Priya Nair · Senior Backend" },
];

/* ── status chip ─────────────────────────────────────────────────────── */
function StatusChip({ status }: { status: string }) {
  const config: Record<string, string> = {
    pending:         "bg-slate-100 text-slate-600",
    extracting:      "bg-blue-100 text-blue-700",
    matching:        "bg-violet-100 text-violet-700",
    processing:      "bg-blue-100 text-blue-700 animate-pulse",
    awaiting_review: "bg-amber-100 text-amber-700",
    completed:       "bg-emerald-100 text-emerald-700",
    failed:          "bg-red-100 text-red-700",
    rejected:        "bg-slate-100 text-slate-500",
  };
  return (
    <span className={`inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-medium capitalize ${config[status] ?? "bg-muted text-muted-foreground"}`}>
      {status.replace("_", " ")}
    </span>
  );
}

/* ── queue item row ──────────────────────────────────────────────────── */
function QueueRow({ item, onApprove, onReject }: {
  item: IngestQueueItem;
  onApprove: (id: string) => void;
  onReject: (id: string) => void;
}) {
  const Icon = item.ingest_type === "cv" ? Inbox : FileText;
  return (
    <div className="flex items-center gap-3 border-b py-3 last:border-0">
      <div className="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-muted">
        <Icon className="h-4 w-4 text-muted-foreground" />
      </div>
      <div className="min-w-0 flex-1">
        <div className="flex items-center gap-2 flex-wrap">
          <span className="text-xs font-semibold capitalize">{item.ingest_type.replace("_", " ")}</span>
          <StatusChip status={item.status} />
          <Badge variant="outline" className="text-[9px] capitalize">{item.source}</Badge>
        </div>
        <p className="text-[11px] text-muted-foreground">{item.created_at?.slice(0, 10)}</p>
      </div>
      {item.status === "awaiting_review" && (
        <div className="flex shrink-0 gap-1">
          <Button size="sm" className="h-7 px-2 text-xs bg-emerald-600 hover:bg-emerald-700" onClick={() => onApprove(item.id)}>
            <CheckCircle2 className="mr-1 h-3 w-3" /> Approve
          </Button>
          <Button size="sm" variant="outline" className="h-7 px-2 text-xs text-red-600 hover:text-red-700" onClick={() => onReject(item.id)}>
            <XCircle className="mr-1 h-3 w-3" /> Reject
          </Button>
        </div>
      )}
      {item.status === "completed" && item.assessment_id && (
        <Link href={`/recruiter/candidates/${item.assessment_id}`}>
          <Button size="sm" variant="ghost" className="h-7 px-2 text-xs">
            View <ChevronRight className="ml-0.5 h-3 w-3" />
          </Button>
        </Link>
      )}
    </div>
  );
}

/* ── page ─────────────────────────────────────────────────────────────── */
export default function AgentCommandCentre() {
  const [queue, setQueue] = useState<IngestQueueItem[]>([]);
  const [events, setEvents] = useState(MOCK_EVENTS);
  const [loading, setLoading] = useState(false);
  const wsRef = useRef<WebSocket | null>(null);

  const loadQueue = async () => {
    setLoading(true);
    try {
      // Simulate API call with mock data
      setQueue([]);
    } catch {
      /* fallback — staging might not have any items yet */
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    loadQueue();
    /* WebSocket real-time feed */
    try {
      const ws = new WebSocket("ws://127.0.0.1:8000/api/v1/agents/ws");
      wsRef.current = ws;
      ws.onmessage = (e) => {
        try {
          const payload = JSON.parse(e.data);
          const msg = payload.event?.replace("_", " ") ?? "event";
          setEvents((prev) => [
            { time: new Date().toLocaleTimeString("en-GB", { hour: "2-digit", minute: "2-digit" }), type: "live", icon: Activity, color: "text-emerald-500", text: `${msg} · ${payload.id?.slice(0, 8)}…` },
            ...prev.slice(0, 19),
          ]);
          loadQueue();
        } catch {}
      };
    } catch {}
    return () => { wsRef.current?.close(); };
  }, []);

  const approved = queue.filter((i) => i.status === "completed").length;
  const pending  = queue.filter((i) => i.status !== "completed" && i.status !== "rejected" && i.status !== "failed").length;
  const review   = queue.filter((i) => i.status === "awaiting_review").length;
  const errors   = queue.filter((i) => i.status === "failed").length;

  const handleApprove = async (id: string) => {
    try { loadQueue(); } catch {}
  };
  const handleReject = async (id: string) => {
    try { loadQueue(); } catch {}
  };

  return (
    <div className="space-y-6">
      {/* header */}
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-bold tracking-tight">Agent Command Centre</h1>
          <p className="text-sm text-muted-foreground">Monitor and control autonomous agents in real-time</p>
        </div>
        <Button size="sm" variant="outline" onClick={loadQueue} disabled={loading}>
          <RefreshCw className={`mr-1.5 h-4 w-4 ${loading ? "animate-spin" : ""}`} /> Refresh
        </Button>
      </div>

      {/* system health strip */}
      <div className="grid grid-cols-2 gap-3 sm:grid-cols-4">
        {[
          { label: "Completed today", value: approved, icon: CheckCircle2, color: "text-emerald-600" },
          { label: "Processing",      value: pending,  icon: Clock,        color: "text-blue-600" },
          { label: "Awaiting review", value: review,   icon: AlertTriangle,color: "text-amber-600" },
          { label: "Errors",          value: errors,   icon: XCircle,      color: "text-red-600" },
        ].map(({ label, value, icon: Icon, color }) => (
          <Card key={label}>
            <CardContent className="flex items-center gap-3 p-4">
              <Icon className={`h-8 w-8 shrink-0 ${color}`} />
              <div>
                <p className="text-2xl font-bold tabular-nums">{value}</p>
                <p className="text-xs text-muted-foreground">{label}</p>
              </div>
            </CardContent>
          </Card>
        ))}
      </div>

      <div className="grid gap-6 lg:grid-cols-[1fr_300px]">

        {/* LEFT — agent cards + queue */}
        <div className="space-y-5">
          {/* agent cards */}
          <div className="grid gap-4 sm:grid-cols-2">
            {[
              { name: "CV Ingestion Agent", running: true,  processed: 47, desc: "Polls inbox/cv/ every 30s · IMAP email", icon: Inbox },
              { name: "JD Analysis Agent",  running: false, processed: 12, desc: "Polls inbox/jd/ every 30s · API-triggered", icon: FileText },
            ].map(({ name, running, processed, desc, icon: Icon }) => (
              <Card key={name}>
                <CardContent className="p-4">
                  <div className="flex items-center gap-3 mb-3">
                    <div className={`flex h-10 w-10 items-center justify-center rounded-full ${running ? "bg-emerald-100" : "bg-muted"}`}>
                      <Icon className={`h-5 w-5 ${running ? "text-emerald-600" : "text-muted-foreground"}`} />
                    </div>
                    <div>
                      <div className="flex items-center gap-2">
                        <span className={`h-2 w-2 rounded-full ${running ? "bg-emerald-400 animate-pulse" : "bg-slate-300"}`} />
                        <p className="text-sm font-semibold">{name}</p>
                      </div>
                      <p className="text-[11px] text-muted-foreground">{desc}</p>
                    </div>
                  </div>
                  <div className="flex items-center justify-between text-xs text-muted-foreground">
                    <span>{processed} processed today</span>
                    <span className="text-emerald-600">0 errors</span>
                  </div>
                </CardContent>
              </Card>
            ))}
          </div>

          {/* quick action */}
          <div className="flex gap-3">
            <Button variant="outline" className="gap-2">
              <Upload className="h-4 w-4" /> Drop a CV
            </Button>
            <Button variant="outline" className="gap-2">
              <Plus className="h-4 w-4" /> Submit JD Draft
            </Button>
          </div>

          {/* ingest queue */}
          <Card>
            <CardHeader className="pb-2">
              <div className="flex items-center justify-between">
                <CardTitle className="text-sm">Ingest Queue</CardTitle>
                <div className="flex gap-1">
                  {["all", "awaiting_review", "processing", "completed"].map((f) => (
                    <button key={f} className="rounded px-2 py-0.5 text-[10px] hover:bg-accent transition-colors capitalize">
                      {f.replace("_", " ")}
                    </button>
                  ))}
                </div>
              </div>
            </CardHeader>
            <CardContent className="pb-2">
              {queue.length === 0 ? (
                <p className="py-8 text-center text-sm text-muted-foreground">
                  Queue is empty — drop a CV or JD draft to get started
                </p>
              ) : (
                queue.map((item) => (
                  <QueueRow key={item.id} item={item} onApprove={handleApprove} onReject={handleReject} />
                ))
              )}
            </CardContent>
          </Card>
        </div>

        {/* RIGHT — live event feed */}
        <Card className="self-start">
          <CardHeader className="pb-2">
            <CardTitle className="flex items-center gap-2 text-sm">
              <Activity className="h-3.5 w-3.5 text-emerald-500" /> Live Events
              <span className="ml-auto h-2 w-2 rounded-full bg-emerald-400 animate-pulse" />
            </CardTitle>
          </CardHeader>
          <CardContent className="pb-2 max-h-[520px] overflow-y-auto">
            {events.map((ev, i) => {
              const Icon = ev.icon;
              return (
                <div key={i} className="flex items-start gap-2 py-2 border-b last:border-0">
                  <Icon className={`mt-0.5 h-3.5 w-3.5 shrink-0 ${ev.color}`} />
                  <p className="flex-1 min-w-0 text-[11px] leading-snug">{ev.text}</p>
                  <span className="text-[10px] tabular-nums text-muted-foreground shrink-0">{ev.time}</span>
                </div>
              );
            })}
          </CardContent>
        </Card>
      </div>
    </div>
  );
}
