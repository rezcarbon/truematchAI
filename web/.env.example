# Public base path the browser uses to reach the BFF proxy (NOT the backend directly).
NEXT_PUBLIC_API_BASE_URL=/api

# NextAuth
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# Server-only: real backend the BFF proxy forwards to. Never exposed to the browser.
BACKEND_API_URL=https://api.truematch.ai/v1

# Server-only service token used by the BFF proxy to authenticate to the backend.
BACKEND_API_TOKEN=
